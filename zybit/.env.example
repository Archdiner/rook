# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# ---------------------------------------------------------------------------
# Auth (invite-only magic-link flow — no Clerk)
# ---------------------------------------------------------------------------

# Full public URL of this deployment, no trailing slash (used in magic-link emails)
APP_BASE_URL=https://getzybit.com

# "From" address for magic-link emails (must be a verified Resend sender)
AUTH_FROM_EMAIL=Zybit <noreply@getzybit.com>

# Password that protects /admin — pick something strong
ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=
NEXT_PUBLIC_DEFAULT_ORG_ID=org_default

# Phase 1 storage driver selection:
# - auto: prefer Postgres when DATABASE_URL exists, otherwise blob/local fallback
# - blob: force blob/local fallback path
# - postgres: force Postgres repository path
PHASE1_STORAGE_DRIVER=auto

# Phase 1 org identity mode:
# - dev: allow x-org-id header, query fallback, then default org id
# - header_required: require x-org-id header (recommended for production)
PHASE1_ORG_IDENTITY_MODE=dev

# Vercel Blob token for /discovery survey response storage
BLOB_READ_WRITE_TOKEN=

# ---------------------------------------------------------------------------
# Headless capture (Phase 2 — capture_v2)
# ---------------------------------------------------------------------------

BROWSERLESS_URL=wss://chrome.browserless.io
BROWSERLESS_TOKEN=

# Feature flag override — set to "1" when Edge Config is unavailable
CAPTURE_V2_ENABLED=

# Cron auth secret — sent as "Authorization: Bearer <secret>" by Vercel cron
FORGE_CRON_SECRET=

# Used by the nightly refresh cron when a site's integration config lacks siteUrl
CAPTURE_SITE_URL_OVERRIDE=

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
AXIOM_TOKEN=
AXIOM_DATASET=
CRONITOR_API_KEY=

# ---------------------------------------------------------------------------
# Edge Config (feature flags)
# ---------------------------------------------------------------------------
EDGE_CONFIG=
